<configuration>
  <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="unknown"/>
  <property name="LOG_PATTERN" value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level service=${serviceName} trace_id=%X{trace_id:-} span_id=%X{span_id:-} logger=%logger{36} message=&quot;%msg&quot;%n"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${LOG_PATTERN}</pattern>
    </encoder>
  </appender>

  <appender name="OTEL" class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
    <captureMdcAttributes>service,operation,trace_id,span_id,error_code</captureMdcAttributes>
    <captureKeyValuePairAttributes>true</captureKeyValuePairAttributes>
    <captureExperimentalAttributes>true</captureExperimentalAttributes>
  </appender>

  <appender name="OTEL_MDC" class="io.opentelemetry.instrumentation.logback.mdc.v1_0.OpenTelemetryAppender">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="OTEL"/>
  </appender>

  <root level="${LOGGING_LEVEL_ROOT:-INFO}">
    <appender-ref ref="OTEL_MDC"/>
  </root>
</configuration>
