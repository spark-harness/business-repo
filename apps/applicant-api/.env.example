SPARK_APPLICANT_AUTH_JDBC_URL=jdbc:postgresql://localhost:5432/app
SPARK_APPLICANT_AUTH_JDBC_USERNAME=forest
SPARK_APPLICANT_AUTH_JDBC_PASSWORD=replace-with-local-password
SPARK_APPLICANT_AUTH_TOKEN_SECRET=replace-with-local-token-secret
SPARK_APPLICANT_AUTH_MIGRATIONS_ENABLED=true
SPARK_APPLICANT_AUTH_CONSUL_ENABLED=true
