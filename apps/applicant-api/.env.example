SPARK_APPLICANT_AUTH_CONSUL_SERVICE_ADDRESS=127.0.0.1
SPARK_GRPC_SERVER_PORT=9090
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=replace-with-local-redis-password
OTEL_TRACES_EXPORTER=none
OTEL_TRACES_SAMPLER_ARG=0.0
