# Local-only defaults. Do not put real secrets in this file.

# Optional local env file path. Defaults to .env.
CONFIG_ENV_FILE=.env

# Startup Consul config source. Keep tokens in private .env, shell, CI, or K8s Secret.
CONFIG_CONSUL_ENABLED=false
CONFIG_CONSUL_SCHEME=http
CONFIG_CONSUL_ADDRESS=127.0.0.1:8500
CONFIG_CONSUL_PATH=config/lendora/fides-bff/config.yaml
# CONFIG_CONSUL_TOKEN=<from-local-env-or-platform-secret>

# Allowlisted no-prefix config keys.
SERVER_HTTP_ADDR=127.0.0.1:8000
SERVER_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

APPLICANT_CONSUL_ADDRESS=127.0.0.1:8500
APPLICANT_CONSUL_SCHEME=http
APPLICANT_CONSUL_SERVICE_NAME=applicant-api
APPLICANT_GRPC_TIMEOUT=3s
APPLICANT_GRPC_PLAINTEXT=true

QUOTE_CONSUL_ADDRESS=127.0.0.1:8500
QUOTE_CONSUL_SCHEME=http
QUOTE_CONSUL_SERVICE_NAME=quote-api
# QUOTE_HTTP_BASE_URL=http://127.0.0.1:8080
QUOTE_HTTP_TIMEOUT=3s

ORIGINATION_CONSUL_ADDRESS=127.0.0.1:8500
ORIGINATION_CONSUL_SCHEME=http
ORIGINATION_CONSUL_SERVICE_NAME=origination-api
# ORIGINATION_HTTP_BASE_URL=http://127.0.0.1:8081
ORIGINATION_HTTP_TIMEOUT=3s

REGISTRY_CONSUL_ENABLED=true
REGISTRY_CONSUL_ADDRESS=127.0.0.1:8500
REGISTRY_CONSUL_SCHEME=http
REGISTRY_CONSUL_DISCOVERY_ADDR=127.0.0.1:8000
REGISTRY_CONSUL_HEARTBEAT=true
REGISTRY_CONSUL_HEALTH_CHECK=true
REGISTRY_CONSUL_HEALTH_CHECK_INTERVAL_SEC=10
REGISTRY_CONSUL_DEREGISTER_AFTER_SEC=60
REGISTRY_CONSUL_METADATA=module=frontend

OBSERVABILITY_OTEL_ENABLED=false
OBSERVABILITY_OTEL_EXPORTER=otlp
OBSERVABILITY_OTEL_ENDPOINT=
OBSERVABILITY_OTEL_PROTOCOL=http/protobuf
OBSERVABILITY_OTEL_HEADERS=
OBSERVABILITY_OTEL_ENVIRONMENT=local
OBSERVABILITY_OTEL_RELEASE=dev
